# Void Trader — Docker-Konfiguration
# Kopieren nach .env und anpassen

# Host-Port auf dem die App erreichbar ist
APP_PORT=8080

# Image-Tag für den Build (z.B. "0.1.0" oder "dev")
APP_VERSION=dev

# Compose-Projektname (beeinflusst Container- und Netzwerknamen)
COMPOSE_PROJECT_NAME=void-trader

# Container-Restart-Verhalten: no | always | on-failure | unless-stopped
RESTART_POLICY=unless-stopped
